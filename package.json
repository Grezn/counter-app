{
  "name": "counter-app",
  "version": "1.0.0",
  "description": "MSP on-call dashboard with Express and Redis/Valkey",
  "main": "server.js",
  "scripts": {
    "api:smoke": "node scripts/api-smoke.mjs",
    "build": "vite build --config frontend/vite.config.mjs",
    "dev:frontend": "vite --config frontend/vite.config.mjs --host 0.0.0.0",
    "incidents:smoke": "node scripts/incidents-service-smoke.mjs",
    "start": "node server.js",
    "mcp": "node mcp/server.mjs",
    "mcp:smoke": "node mcp/smoke-test.mjs",
    "weather:smoke": "node scripts/weather-service-smoke.mjs",
    "verify": "npm run build && npm run weather:smoke && npm run incidents:smoke && npm run api:smoke && npm run mcp:smoke"
  },
  "dependencies": {
    "express": "^4.19.2",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "vite": "^8.0.16",
    "vue": "^3.5.35",
    "zod": "^4.4.3"
  }
}
