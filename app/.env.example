# 複製成 .env 後再填正式值。
# 真正的 .env 可能有秘密，不要 commit 到 GitHub。

IMAGE_URI=your-account-id.dkr.ecr.us-east-1.amazonaws.com/docker-demo:latest
APP_VERSION=local

# REDIS_URL 和 REDIS_HOST/REDIS_PORT 擇一使用即可。
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_CONNECT_TIMEOUT_MS=3000
REDIS_CONNECT_MAX_RETRIES=5

# Reset 按鈕會用到。正式環境請換成夠長的隨機字串。
RESET_TOKEN=change-me-to-a-long-random-token

# Jira 小卡建立功能。Token 只放後端環境變數，不要放到前端 HTML/JS。
JIRA_BASE_URL=https://metaage-corp-p400.atlassian.net
JIRA_REST_BASE_URL=
JIRA_EMAIL=oncall@example.com
JIRA_API_TOKEN=put-a-new-token-here
JIRA_PROJECT_KEY=PMP
JIRA_ISSUE_TYPE=交接事項
JIRA_ISSUE_TYPE_ID=
JIRA_LABELS=電話連絡,noc-oncall
JIRA_DEFAULT_PRIORITY=
